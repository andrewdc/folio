---
import Cta from '../components/Cta.astro';
const { title, address, text } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="p-4 md:p-8 lg:p-10">
  <div class="mx-auto max-w-screen-xl text-center">
    <a
      href="https://www.linkedin.com/in/andrewdc"
      class="flex justify-center items-center text-2xl font-semibold text-white hover:underline"
    >
      {title}
    </a>

    <Cta />
    <div class="fp">© {new Date().getFullYear()} Andrew Colclough</div>
  </div>
  <slot />
</footer>

<style>
  footer {
    margin-top: var(--space-lg);
    background-color: #000;
  }
  .fp {
    color:#666;
  }
  @media (max-width: 768px) {
    footer {
      padding-bottom:75px;
    }
  }
</style>
